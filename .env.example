# Required for production auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Required for real AI features. Never hardcode this in source.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: production database. If omitted, the app uses local JSON storage for demos.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local file override for smoke tests
HOT_TAKE_STORE_PATH=
